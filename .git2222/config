[core]
	repositoryformatversion = 0
	filemode = false
	bare = false
	logallrefupdates = true
	symlinks = false
	ignorecase = true
[submodule]
	active = .
[remote "origin"]
	url = https://github.com/kamil-ochnio/playwright_training.git
	fetch = +refs/heads/*:refs/remotes/origin/*
[branch "main"]
	remote = origin
	merge = refs/heads/main
[commit]
	template = .gitmessage
[branch "main"]
	vscode-merge-base = origin/main
	remote = origin
	merge = refs/heads/pageObject
